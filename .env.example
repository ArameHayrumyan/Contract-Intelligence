# ---------------------------------------------------------------------------
# Secure Contract Intelligence & SLA Auditor — environment template
# Copy to `.env` and fill in. NEVER commit a real `.env`.
# ---------------------------------------------------------------------------

# --- Core -------------------------------------------------------------------
# dev | staging | production
ENVIRONMENT=dev

# Provider selection is ENVIRONMENT-GATED:
#   dev/staging may use free tiers: groq_free | gemini_free
#   production MUST use a paid tier: openai | anthropic | azure_openai | groq_paid
#   (booting production on a free tier raises ConfigurationError — by design.)
LLM_PROVIDER=groq_free

LOG_LEVEL=INFO
LOG_DIR=logs

# --- Upload security --------------------------------------------------------
MAX_UPLOAD_BYTES=26214400   # 25 MiB
MAX_PAGES=300

# --- Processing -------------------------------------------------------------
OCR_CHAR_THRESHOLD=100

# --- Storage ----------------------------------------------------------------
CHROMA_PERSIST_DIR=data/chroma
# Audit-results database (SQLite; PostgreSQL at production scale — see SCALING_PATH).
SQLITE_DB_PATH=data/audits/audit_store.db
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Optional. The embedding model is pre-baked into the API image, so no runtime
# HuggingFace download (or token) is normally needed. Set this only if you swap
# EMBEDDING_MODEL to one that requires auth or you hit Hub download rate limits.
HF_TOKEN=

# --- Generation tuning ------------------------------------------------------
LLM_TEMPERATURE=0.0
LLM_MAX_RETRIES=5

# --- Access gate (Section 6) ------------------------------------------------
# Shared access code for the web gate. Distinct from any API key.
ACCESS_CODE=change-me-locally

# Backend stub API key (web → api). Replaced by OIDC at scale.
API_KEY=demo-key-tenant-acme

# --- Provider credentials (only the active provider's is required) ----------
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-06-01

# --- Web → API wiring (used by docker compose) ------------------------------
API_BASE_URL=http://localhost:8000

# --- Production deploy (docker-compose.prod.yml) ----------------------------
SITE_DOMAIN=yourproject.dev
REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest
